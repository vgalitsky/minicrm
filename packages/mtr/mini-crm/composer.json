{
  "name": "mtr/mini-crm",
  "description": "Mini CRM package",
  "type": "library",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "Mtr\\MiniCrm\\": "src/",
      "Mtr\\MiniCrm\\Database\\Factories\\": "database/factories/",
      "Mtr\\MiniCrm\\Database\\Seeders\\": "database/seeders/"
    }
  },
  "require": {
    "php": "^8.4"  
  },
  "extra": {
    "laravel": {
      "providers": [
        "Mtr\\MiniCrm\\MiniCrmServiceProvider"
      ]
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}